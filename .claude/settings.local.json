{
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash",
      "mcp__playwright",
      "WebFetch(domain:smithery.ai)",
      "WebFetch(domain:github.com)",
      "Skill(git:commit)",
      "mcp__sequential-thinking",
      "WebFetch(domain:ui.shadcn.com)",
      "mcp__shadcn",
      "WebFetch(domain:registry.modelcontextprotocol.io)",
      "WebFetch(domain:developers.figma.com)",
      "WebFetch(domain:help.figma.com)",
      "WebFetch(domain:www.npmjs.com)",
      "mcp__figma",
      "WebFetch(domain:www.untitledui.com)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "playwright"
  ],
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/format-on-save.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/log-bash.sh"
          }
        ]
      }
    ]
  }
}
